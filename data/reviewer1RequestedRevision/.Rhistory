D.c1$V3 = max(D.c1$V3)-D.c1$V3
D.c2 = rbind(cond26005, cond260010, cond27005, cond270010, cond28005, cond280010)
D.c2$V3 = max(D.c2$V3)-D.c2$V3
D.c3 = rbind(cond36005, cond360010, cond37005, cond370010, cond38005, cond380010)

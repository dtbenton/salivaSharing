# To play with the model in non-automation model, simply run "plainSim" in the simulator once it's loaded.
# you can run the simulator by typing "lens simModel.in" in a terminal.

proc plainSim {} {
addNet salivaSim 

# input groups
addGroup Object_Left_IN 104 INPUT  
addGroup Object_Right_IN 104 INPUT  
addGroup saliva_left_identity_IN 2 INPUT
addGroup saliva_right_identity_IN 2 INPUT 
addGroup comfort_right_identity_IN 2 INPUT
addGroup comfort_left_identity_IN 2 INPUT 
addGroup Distress_IN 2 INPUT 
addGroup Action_IN 2 INPUT
addGroup Comfort_IN 2 INPUT  
addGroup Food_IN 5 INPUT
  

# hidden group (# there are necessarily fewer hidden units than there are input and output units)
addGroup hidden 30 
	
# output group
addGroup Object_Left_OUT 104 OUTPUT  
addGroup Object_Right_OUT 104 OUTPUT  
addGroup saliva_left_identity_OUT 2 OUTPUT  
addGroup saliva_right_identity_OUT 2 OUTPUT
addGroup comfort_left_identity_OUT 2 OUTPUT  
addGroup comfort_right_identity_OUT 2 OUTPUT
addGroup Distress_OUT 2 OUTPUT 
addGroup Action_OUT 2 OUTPUT 
addGroup Comfort_OUT 2 OUTPUT 
addGroup Food_OUT 5 OUTPUT

# connect groups (input -> hidden -> output)
connectGroups {Object_Left_IN Object_Right_IN saliva_left_identity_IN saliva_right_identity_IN comfort_right_identity_IN comfort_left_identity_IN Distress_IN Action_IN Comfort_IN Food_IN} hidden {Object_Left_OUT Object_Right_OUT saliva_left_identity_OUT saliva_right_identity_OUT comfort_right_identity_OUT comfort_left_identity_OUT Distress_OUT Action_OUT Comfort_OUT Food_OUT}

deleteGroups bias

# training examples
loadExamples pretrain.ex -e PERMUTED
loadExamples familiarization_exp_2b.ex
loadExamples familiarization_exp_3b.ex
loadExamples familiarization_comfortDistress.ex
loadExamples test_ComfortingDistress.ex
loadExamples test_ComfortingDistress_control.ex
loadExamples test_exp_2b.ex
loadExamples test_exp_2d.ex


# set learning and display parameters
setObj learningRate 0.1
setObj momentum	    0
setObj batchSize    0
setObj numUpdates   10
setObj reportInterval 1
setObj unitCellSize 12
setObj linkCellSize 10
setObj randRange 0.1
setObj pseudoExampleFreq 1

	
resetPlot 
plotRow 10 b 1 n Object_Left_OUT 10 b 4 rnext Object_Right_OUT 10
plotRow 2 b 1 n saliva_left_identity_OUT 2 b 5 n comfort_left_identity_OUT 2 b 5 n saliva_right_identity_OUT 2 b 5 n comfort_right_identity_OUT 2
plotRow 2 b 1 n Comfort_OUT 2 b 8 lnext Distress_OUT 2 b 5 n Action_OUT 2
plotRow 2 b 1 n Food_OUT 5
plotRow 8 b 8 n hidden 10 
plotRow 2 b 1 n Food_IN 5
plotRow 2 b 1 n Comfort_IN 2 b 8 lnext Distress_IN 2 b 5 n Action_IN 2
plotRow 2 b 1 n saliva_left_identity_IN 2 b 5 n comfort_left_identity_IN 2 b 5 n saliva_right_identity_IN 2 b 5 n comfort_right_identity_IN 2
plotRow 10 b 1 n Object_Left_IN 10 b 4 rnext Object_Right_IN 10
viewUnits


# name units for increased model interpretability

# object_left_animate_status IN and OUT
setObj group(2).unit(0).name "saliva sharer"
setObj group(2).unit(1).name "non-saliva sharer"

setObj group(13).unit(0).name "saliva sharer"
setObj group(13).unit(1).name "non-saliva sharer"

setObj group(3).unit(0).name "saliva sharer"
setObj group(3).unit(1).name "non-saliva sharer"

setObj group(14).unit(0).name "saliva sharer"
setObj group(14).unit(1).name "non-saliva sharer"

setObj group(4).unit(0).name "comforter"
setObj group(4).unit(1).name "non-comforter"

setObj group(15).unit(0).name "comforter"
setObj group(15).unit(1).name "non-comforter"

setObj group(5).unit(0).name "comforter"
setObj group(5).unit(1).name "non-comforter"

setObj group(16).unit(0).name "comforter"
setObj group(16).unit(1).name "non-comforter"

setObj group(6).unit(0).name "distressed"
setObj group(6).unit(1).name "non-distressed"

setObj group(17).unit(0).name "distressed"
setObj group(17).unit(1).name "non-distressed"

setObj group(7).unit(0).name "saliva sharing"
